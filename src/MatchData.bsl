// Функция сопоставляет загруженные данные с номенклатурой в базе
// Возвращает Таблицу Значений с результатами сравнения
Функция СопоставитьДанныеСБазой(ТаблицаИзФайла) Экспорт
	
	Запрос = Новый Запрос;
	
	// 1. Передаем таблицу из файла во временную таблицу запроса
	// Это критически важно для производительности!
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	ВТ_Загрузка.Артикул КАК Артикул,
		|	ВТ_Загрузка.Цена КАК ЦенаФайла
		|ПОМЕСТИТЬ ВТ_ДанныеФайла

		|ИЗ
		|	&ТаблицаИзФайла КАК ВТ_Загрузка";
	
	Запрос.УстановитьПараметр("ТаблицаИзФайла", ТаблицаИзФайла);
	Запрос.Выполнить();
	
	// 2. Основной запрос: Соединяем данные файла с основной базой 1С
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	ВТ_Файл.Артикул КАК АртикулФайла,
		|	ВТ_Файл.ЦенаФайла КАК ЦенаФайла,
		|	ЕСТЬNULL(СправочникНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК ТоварСсылка,

		|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК ЦенаВБазе
		|ИЗ
		|	ВТ_ДанныеФайла КАК ВТ_Файл

		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ВТ_Файл.Артикул = СправочникНоменклатура.Артикул
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних КАК ЦеныНоменклатурыСрезПоследних
		|		ПО (СправочникНоменклатура.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Возвращаем результат в виде Таблицы Значений для отображения на форме
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции

// Процедура создает новый документ "Заказ поставщику" на основании сопоставленных данных
Процедура СоздатьЗаказПоставщику(ТаблицаДанных, Поставщик) Экспорт
	
	// 1. Создаем объект нового документа
	НовыйЗаказ = Документы.ЗаказПоставщику.СоздатьДокумент();
	
	// 2. Заполняем "шапку" документа
	НовыйЗаказ.Дата = ТекущаяДата();
	НовыйЗаказ.Контрагент = Поставщик; // Ссылочный тип
	НовыйЗаказ.Статус = Перечисления.СтатусыЗаказовПоставщикам.Подтвержден;
	
	// 3. Заполняем табличную часть "Товары"
	Для Каждого СтрокаДанных Из ТаблицаДанных Цикл
		
		// Проверяем, что товар был найден в базе (не пустая ссылка)
		Если ЗначениеЗаполнено(СтрокаДанных.ТоварСсылка) Тогда
			
			НоваяСтрока = НовыйЗаказ.Товары.Добавить();
			НоваяСтрока.Номенклатура = СтрокаДанных.ТоварСсылка;
			НоваяСтрока.Количество   = 1; // Можно брать из файла
			НоваяСтрока.Цена         = СтрокаДанных.ЦенаФайла;
			
		КонецЕсли;
		
	КонецЦикла;
	
	// 4. Записываем документ с проведением в блоке Попытка
	Попытка
		НовыйЗаказ.Записать(РежимЗаписиДокумента.Проведение);
		Сообщить("Документ успешно создан и проведен: " + НовыйЗаказ.Ссылка);
	Исключение
		// Если проведение не удалось (например, нет остатков или прав), просто записываем
		НовыйЗаказ.Записать(РежимЗаписиДокумента.Запись);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ записан, но не проведен: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры

// Фишка: Создание документов в единой транзакции с логированием
Процедура СоздатьПакетЗаказовБезопасно(ТаблицаДанных) Экспорт
	
	ТекстЛога = "";
	НачатьТранзакцию();
	
	Попытка
		// Здесь вызываем логику создания (наш код выше)
		Для Каждого ГруппаПоставщика Из ТаблицаДанных Цикл 
			// Представим, что мы группируем строки по поставщикам
			СоздатьЗаказПоставщику(ГруппаПоставщика.Строки, ГруппаПоставщика.Поставщик);
		КонецЦикла;
		
		ЗафиксироватьТранзакцию();
		Сообщить("Все данные успешно загружены в базу.");
		
	Исключение
		ОтменитьТранзакцию();
		ТекстЛога = "Ошибка при записи пакета данных: " + ОписаниеОшибки();
		// Записываем ошибку в Журнал Регистрации (показываем знание администрирования)
		ЗаписьЖурналаРегистрации("ЗагрузкаПрайсов", УровеньЖурналаРегистрации.Ошибка,,, ТекстЛога);
		Сообщить("Операция отменена. Подробности в Журнале Регистрации.");
	КонецПопытки;
	
КонецПроцедуры
