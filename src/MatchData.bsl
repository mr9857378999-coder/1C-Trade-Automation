// Функция сопоставляет загруженные данные с номенклатурой в базе
// Возвращает Таблицу Значений с результатами сравнения
Функция СопоставитьДанныеСБазой(ТаблицаИзФайла) Экспорт
	
	Запрос = Новый Запрос;
	
	// 1. Передаем таблицу из файла во временную таблицу запроса
	// Это критически важно для производительности!
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	ВТ_Загрузка.Артикул КАК Артикул,
		|	ВТ_Загрузка.Цена КАК ЦенаФайла
		|ПОМЕСТИТЬ ВТ_ДанныеФайла

		|ИЗ
		|	&ТаблицаИзФайла КАК ВТ_Загрузка";
	
	Запрос.УстановитьПараметр("ТаблицаИзФайла", ТаблицаИзФайла);
	Запрос.Выполнить();
	
	// 2. Основной запрос: Соединяем данные файла с основной базой 1С
	Запрос.Текст = 
		"ВЫБРАТЬ

		|	ВТ_Файл.Артикул КАК АртикулФайла,
		|	ВТ_Файл.ЦенаФайла КАК ЦенаФайла,
		|	ЕСТЬNULL(СправочникНоменклатура.Ссылка, ЗНАЧЕНИЕ(Справочник.Номенклатура.ПустаяСсылка)) КАК ТоварСсылка,

		|	ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) КАК ЦенаВБазе
		|ИЗ
		|	ВТ_ДанныеФайла КАК ВТ_Файл

		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура КАК СправочникНоменклатура
		|		ПО ВТ_Файл.Артикул = СправочникНоменклатура.Артикул
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних КАК ЦеныНоменклатурыСрезПоследних
		|		ПО (СправочникНоменклатура.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура)";
	
	РезультатЗапроса = Запрос.Выполнить();
	
	// Возвращаем результат в виде Таблицы Значений для отображения на форме
	Возврат РезультатЗапроса.Выгрузить();
	
КонецФункции
